<div class="row mb-4">
  <div class="col">
    <h1>Interface WireGuard</h1>
  </div>
</div>

{{#if systemInterfaces.length}}
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-warning">
        <div class="card-header bg-warning bg-opacity-10">
          <h5 class="mb-0">Interfaces système détectées</h5>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3">
            Les interfaces suivantes existent dans /etc/wireguard/ mais ne sont pas encore dans la base.
            Importez-les pour les gérer depuis l'interface web.
          </p>
          <div class="d-flex flex-wrap gap-2">
            {{#each systemInterfaces}}
              <form method="POST" action="/interface/import/{{this}}" class="d-inline">
                <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                <button type="submit" class="btn btn-sm btn-outline-warning">Importer {{this}}</button>
              </form>
            {{/each}}
          </div>
        </div>
      </div>
    </div>
  </div>
{{/if}}

{{#unless hasInterfaces}}
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0">Initialiser une interface</h5>
        </div>
        <div class="card-body">
          <p class="text-muted">Configurez votre interface WireGuard. Les clés seront générées automatiquement.</p>
          <form method="POST" action="/interface" data-validate>
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <div class="mb-3">
              <label for="nom" class="form-label">Nom de l'interface</label>
              <input type="text" class="form-control" id="nom" name="nom" placeholder="wg0" pattern="wg[0-9]+" required>
              <div class="form-text">Format : wg0, wg1, wg2…</div>
            </div>
            <div class="mb-3">
              <label for="adresse_ip" class="form-label">Adresse IP</label>
              <input type="text" class="form-control" id="adresse_ip" name="adresse_ip" placeholder="10.0.0.1/24" required>
            </div>
            <div class="mb-3">
              <label for="port" class="form-label">Port d'écoute</label>
              <input type="number" class="form-control" id="port" name="port" value="51820" min="1" max="65535" required>
              <div class="form-text">N'oubliez pas d'ouvrir ce port sur votre routeur (redirection de port) pour les connexions distantes.</div>
            </div>
            <div class="mb-3">
              <label for="endpoint" class="form-label">Point de terminaison (optionnel)</label>
              <input type="text" class="form-control" id="endpoint" name="endpoint" placeholder="votre-domaine.com">
              <div class="form-text">Adresse publique (IP ou domaine) pour l'accès depuis l'extérieur. Le port est automatiquement ajouté. Si vide, l'IP du tunnel est utilisée.</div>
            </div>
            <div class="d-grid">
              <button type="submit" class="btn btn-primary">Initialiser l'interface</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
{{/unless}}

{{#if hasInterfaces}}
  <div class="row mb-3">
    <div class="col d-flex gap-2">
      <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#newInterfaceForm">
        + Nouvelle interface
      </button>
      <form method="POST" action="/interface/detect" class="d-inline">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <button type="submit" class="btn btn-outline-info">Détecter</button>
      </form>
    </div>
  </div>

  <div class="collapse mb-4" id="newInterfaceForm">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Initialiser une interface</h5>
          </div>
          <div class="card-body">
          <form method="POST" action="/interface" data-validate>
              <input type="hidden" name="_csrf" value="{{csrfToken}}">
              <div class="mb-3">
                <label for="nom" class="form-label">Nom de l'interface</label>
                <input type="text" class="form-control" id="nom" name="nom" placeholder="wg0" pattern="wg[0-9]+" required>
              </div>
              <div class="mb-3">
                <label for="adresse_ip" class="form-label">Adresse IP</label>
                <input type="text" class="form-control" id="adresse_ip" name="adresse_ip" placeholder="10.0.0.1/24" required>
              </div>
              <div class="mb-3">
                <label for="port" class="form-label">Port d'écoute</label>
                <input type="number" class="form-control" id="port" name="port" value="51820" min="1" max="65535" required>
                <div class="form-text">N'oubliez pas d'ouvrir ce port sur votre routeur (redirection de port) pour les connexions distantes.</div>
              </div>
              <div class="mb-3">
                <label for="endpoint" class="form-label">Point de terminaison (optionnel)</label>
                <input type="text" class="form-control" id="endpoint" name="endpoint" placeholder="votre-domaine.com">
                <div class="form-text">Adresse publique (IP ou domaine) pour l'accès depuis l'extérieur. Le port est automatiquement ajouté.</div>
              </div>
              <div class="d-grid">
                <button type="submit" class="btn btn-primary">Initialiser</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    {{#each interfaces}}
      <div class="col-md-6">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">{{nom}}</h5>
            {{#if active}}
              <span class="badge bg-success">Actif</span>
            {{else}}
              <span class="badge bg-secondary">Inactif</span>
            {{/if}}
          </div>
          <div class="card-body">
            <div class="table-responsive">
            <table class="table table-sm">
              <tbody>
                <tr>
                  <th>Adresse IP</th>
                  <td>{{adresse_ip}}</td>
                </tr>
                <tr>
                  <th>Port</th>
                  <td>{{port}}</td>
                </tr>
                {{#if endpoint}}
                <tr>
                  <th>Point de terminaison</th>
                  <td><code class="text-break small">{{endpoint}}</code></td>
                </tr>
                {{/if}}
                <tr>
                  <th>Clé publique</th>
                  <td><code class="text-break small">{{public_key}}</code></td>
                </tr>
                <tr>
                  <th>Pairs connectés</th>
                  <td>{{connectedPeers}} / {{peerCount}}</td>
                </tr>
                <tr>
                  <th>Download</th>
                  <td class="text-success">{{totalRx}}</td>
                </tr>
                <tr>
                  <th>Upload</th>
                  <td class="text-primary">{{totalTx}}</td>
                </tr>
              </tbody>
            </table>
            </div>

            {{#if routing}}
              {{#unless routing.allOk}}
                <div class="alert alert-warning small py-2 my-3">
                  <strong>Routage non configuré.</strong>
                  Les pairs connectés ne pourront pas accéder au réseau.
                  <button class="btn btn-sm btn-outline-warning mt-1" type="button" data-bs-toggle="collapse" data-bs-target="#routingCmds{{id}}">
                    Voir les commandes
                  </button>
                  <div class="collapse mt-2" id="routingCmds{{id}}">
                    <code class="d-block text-bg-dark p-2 rounded small" style="white-space: pre-wrap;">
{{routing.phy}} — {{routing.subnet}}
{{#if routing.masquerade}}✅ MASQUERADE{{else}}❌ MASQUERADE{{/if}}
{{#if routing.forwardIn}}✅ FORWARD IN{{else}}❌ FORWARD IN{{/if}}
{{#if routing.forwardOut}}✅ FORWARD OUT{{else}}❌ FORWARD OUT{{/if}}
                    </code>
                    <div class="mt-2">
                      <strong>Commandes iptables :</strong>
                      <code class="d-block text-bg-dark p-2 rounded small mt-1" style="white-space: pre-wrap;">
{{#each routing.iptablesCmds}}{{this}}
{{/each}}</code>
                      {{#if routing.firewallCmds.length}}
                        <strong>Ou avec {{routing.firewallType}} (alternative) :</strong>
                        <code class="d-block text-bg-dark p-2 rounded small mt-1" style="white-space: pre-wrap;">
{{#each routing.firewallCmds}}{{this}}
{{/each}}</code>
                      {{/if}}
                    </div>
                  </div>
                </div>
              {{/unless}}
            {{/if}}

            <div class="d-flex gap-2 mt-3">
              <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editIface{{id}}">Éditer</button>
              <form method="POST" action="/interface/{{id}}/toggle" class="d-inline">
                <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                {{#if active}}
                  <button type="submit" class="btn btn-sm btn-outline-warning">Arrêter</button>
                {{else}}
                  <button type="submit" class="btn btn-sm btn-outline-success">Démarrer</button>
                {{/if}}
              </form>
              <form method="POST" action="/interface/{{id}}/delete" class="d-inline" onsubmit="return confirm('Supprimer l\\'interface {{nom}} ? Cette action est irréversible.')">
                <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
              </form>
              <a href="/peers?interface={{id}}" class="btn btn-sm btn-outline-primary ms-auto">Gérer les pairs</a>
            </div>

            <div class="modal fade" id="editIface{{id}}" tabindex="-1" aria-hidden="true">
              <div class="modal-dialog">
                <div class="modal-content">
                  <form method="POST" action="/interface/{{id}}/edit">
                    <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                    <div class="modal-header">
                      <h5 class="modal-title">Éditer {{nom}}</h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                      <div class="mb-3">
                        <label for="adresse_ip{{id}}" class="form-label">Adresse IP</label>
                        <input type="text" class="form-control" id="adresse_ip{{id}}" name="adresse_ip" value="{{adresse_ip}}" pattern="^(\d{1,3}\.){3}\d{1,3}\/\d{1,2}$" required>
                      </div>
                      <div class="mb-3">
                        <label for="port{{id}}" class="form-label">Port d'écoute</label>
                        <input type="number" class="form-control" id="port{{id}}" name="port" value="{{port}}" min="1" max="65535" required>
                        <div class="form-text">N'oubliez pas d'ouvrir ce port sur votre routeur (redirection de port) pour les connexions distantes.</div>
                      </div>
                      <div class="mb-3">
                        <label for="endpoint{{id}}" class="form-label">Point de terminaison (optionnel)</label>
                        <input type="text" class="form-control" id="endpoint{{id}}" name="endpoint" value="{{endpoint}}" placeholder="votre-domaine.com">
                        <div class="form-text">Adresse publique (IP ou domaine) pour l'accès depuis l'extérieur. Le port est automatiquement ajouté.</div>
                      </div>
                    </div>
                    <div class="modal-footer">
                      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                      <button type="submit" class="btn btn-primary">Enregistrer</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
{{/if}}
