<div class="row justify-content-center mt-4">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow text-center">
      <div class="card-body p-4">
        <h4 class="card-title mb-3">{{peerName}}</h4>
        <img src="{{qrDataUrl}}" alt="QR Code {{peerName}}" class="img-fluid">
        <p class="text-muted small mt-3 mb-0">
          {{__ 'qrcode.description'}}
        </p>
        <div class="mt-3">
          <a href="/peers" class="btn btn-outline-secondary">{{__ 'qrcode.btn_back'}}</a>
        </div>
      </div>
    </div>
  </div>
</div>
