<div class="row mb-4">
  <div class="col">
    <h1>Tableau de bord</h1>
    <p class="text-muted">Gérez vos interfaces et pairs WireGuard depuis ici.</p>
  </div>
</div>

{{#if selectedInterfaceName}}
<div class="row mb-4">
  <div class="col">
    <div class="alert alert-info">
      Interface active : <strong>{{selectedInterfaceName}}</strong>
      {{#if hasInterfaces}}
        — <a href="/peers">Voir les pairs</a>
      {{/if}}
    </div>
  </div>
</div>
{{/if}}

<div class="row g-3">
  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Interface WireGuard</h5>
        <p class="card-text text-muted">Configurer et gérer votre interface VPN.</p>
        <a href="/interface" class="btn btn-outline-primary">Gérer les interfaces</a>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Pairs (Peers)</h5>
        <p class="card-text text-muted">Ajouter, supprimer et télécharger les configurations clients.</p>
        <a href="/peers" class="btn btn-outline-primary">Gérer les pairs</a>
      </div>
    </div>
  </div>
</div>
