<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card">
      <div class="card-body">
        <h2 class="card-title text-center mb-4">{{__ 'auth.totp.title'}}</h2>
        <p class="text-center text-muted mb-4">
          {{__ 'auth.totp.description'}}
        </p>
        <form method="POST" action="/auth/totp" data-validate>
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          <div class="mb-3">
            <label for="totp_token" class="form-label">{{__ 'auth.totp.code_label'}}</label>
            <input
              type="text"
              class="form-control text-center"
              id="totp_token"
              name="totp_token"
              placeholder="{{__ 'auth.totp.code_placeholder'}}"
              inputmode="numeric"
              pattern="[0-9]{6}"
              maxlength="6"
              required
              autofocus
            >
          </div>
          <div class="d-grid">
            <button type="submit" class="btn btn-primary">{{__ 'auth.totp.submit'}}</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
