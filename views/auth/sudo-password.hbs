<div class="row justify-content-center mt-5">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow">
      <div class="card-body p-4">
        <h4 class="card-title text-center mb-4">Mot de passe sudo</h4>
        <p class="text-muted text-center small mb-4">
          WireGuard-WUI a besoin du mot de passe sudo pour exécuter les commandes WireGuard.
        </p>
        <form method="POST" action="/auth/sudo-password" data-validate>
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          <div class="mb-3">
            <label for="password" class="form-label">Mot de passe sudo</label>
            <input type="password" class="form-control" id="password" name="password" required autofocus>
          </div>
          {{#if hasSudoPassword}}
            <div class="d-grid gap-2">
              <button type="submit" class="btn btn-primary">Mettre à jour</button>
              <a href="/auth/sudo-clear" class="btn btn-outline-danger">Effacer le mot de passe</a>
            </div>
          {{else}}
            <div class="d-grid">
              <button type="submit" class="btn btn-primary">Valider</button>
            </div>
          {{/if}}
        </form>
      </div>
    </div>
  </div>
</div>
