<div class="row justify-content-center mt-5">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow">
      <div class="card-body p-4">
        <h4 class="card-title text-center mb-4">{{__ 'auth.sudo.title'}}</h4>
        <p class="text-muted text-center small mb-4">
          {{__ 'auth.sudo.description'}}
        </p>
        <form method="POST" action="/auth/sudo-password" data-validate>
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          <div class="mb-3">
            <label for="password" class="form-label">{{__ 'auth.sudo.password_label'}}</label>
            <input type="password" class="form-control" id="password" name="password" required autofocus>
          </div>
          {{#if hasSudoPassword}}
            <div class="d-grid gap-2">
              <button type="submit" class="btn btn-primary">{{__ 'auth.sudo.btn_update'}}</button>
              <a href="/auth/sudo-clear" class="btn btn-outline-danger">{{__ 'auth.sudo.btn_clear'}}</a>
            </div>
          {{else}}
            <div class="d-grid">
              <button type="submit" class="btn btn-primary">{{__ 'auth.sudo.btn_validate'}}</button>
            </div>
          {{/if}}
        </form>
      </div>
    </div>
  </div>
</div>
