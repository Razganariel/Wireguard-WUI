<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <p class="text-center text-muted mb-4">{{__ 'auth.login.subtitle'}}</p>
    <div class="card">
      <div class="card-body">
        <h2 class="card-title text-center mb-4">{{__ 'auth.login.title'}}</h2>
        <form method="POST" action="/auth/login" data-validate>
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          <div class="mb-3">
            <label for="email" class="form-label">{{__ 'auth.login.email_label'}}</label>
            <input
              type="email"
              class="form-control"
              id="email"
              name="email"
              placeholder="{{__ 'auth.login.email_placeholder'}}"
              required
              autofocus
            >
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">{{__ 'auth.login.password_label'}}</label>
            <input
              type="password"
              class="form-control"
              id="password"
              name="password"
              placeholder="{{__ 'auth.login.password_placeholder'}}"
              required
            >
          </div>
          <div class="d-grid">
            <button type="submit" class="btn btn-primary">{{__ 'auth.login.submit'}}</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
